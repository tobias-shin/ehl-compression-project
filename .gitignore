# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Compiled C binaries (preprocess builds locally; src + Makefile are tracked)
jax_compress/nncp/preprocess
jax_compress/nncp/*.o
jax_compress/nncp/*.d

# Input data files (downloaded separately; too large for git)
# Tracked: jax_compress/data is otherwise empty of source-controlled content.
jax_compress/data/enwik4
jax_compress/data/enwik5
jax_compress/data/enwik6
jax_compress/data/enwik7
jax_compress/data/enwik8
jax_compress/data/enwik9

# Per-run intermediate files generated by NNCP preprocess + the AC encoder.
# These get rewritten on every run; tracking them only creates churn.
jax_compress/data/preprocessed.dat
jax_compress/data/compressed.dat
jax_compress/data/decompressed.dat
jax_compress/data/dictionary.words
jax_compress/data/final.dat

# Per-run artifact directories (compressed.dat copies, etc.) and TB logs.
jax_compress/data/*_artifacts/
jax_compress/data/tensorboard/

# Papermill-executed notebooks (intermediate outputs of each run).
# The source notebook (torch_compress.ipynb) is tracked; the run outputs aren't.
jax_compress/runs/

# Plot output: regenerated from plot_bpc.py, but we DO commit it because it's
# the headline figure referenced in markdown. Not ignored.
# !jax_compress/data/bpc_vs_size.png  -- already tracked.

# External reference repos. Vendored locally for inspection but not part of
# this project's source tree. Re-fetch from upstream if needed.
nncp_v2-2021-02-06-1/
tensorflow-compress/
